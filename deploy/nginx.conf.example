# 안기모 nginx 설정 예시 — Cafe24 가상서버 (CLAUDE.md §2, §2-2)
# /etc/nginx/sites-available/angimo 로 복사 후 심볼릭 링크

server {
    listen 80;
    server_name angimo.example.com;

    # 정적 자산: nginx 직접 서빙 + 30일 캐시 (Flask 미경유)
    location /static/ {
        alias /srv/angimo/static/;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
    }

    # 업로드: nginx 직접 서빙 — 단, 인증 서류는 차단 (admin 전용 라우트로만, §11)
    location /uploads/verification/ {
        deny all;
        return 403;
    }
    location /uploads/ {
        alias /srv/angimo/uploads/;
        expires 7d;
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    gzip on;
    gzip_types text/css application/javascript application/json application/xml text/plain;
    client_max_body_size 12m;   # 서류 업로드 10MB + 여유
}
